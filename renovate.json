{
  "extends": [
    "config:base",
    "schedule:monthly"
  ],
  "packageRules": [
    {
      "matchPackagePatterns": ["*"],
      "rangeStrategy": "bump"
    },
    {
      "matchManagers": ["github-actions"],
      "groupName": "GitHub Actions",
      "automerge": false
    },
    {
      "groupName": "ia deps",
      "matchPackagePatterns": ["^@internetarchive/"],
      "automerge": false
    },
    {
      "groupName": "test deps",
      "matchPackageNames": [
        "@babel/eslint-parser",
        "@open-wc/testing-helpers",
        "@types/jest",
        "eslint",
        "eslint-plugin-no-jquery",
        "eslint-plugin-testcafe",
        "jest",
        "jest-environment-jsdom",
        "sinon",
        "testcafe"
      ],
      "automerge": false
    },
    {
      "groupName": "build deps",
      "matchPackageNames": [
        "@babel/core",
        "@babel/plugin-proposal-class-properties",
        "@babel/plugin-proposal-decorators",
        "@babel/preset-env",
        "babel-loader",
        "core-js",
        "regenerator-runtime",
        "sass",
        "svgo",
        "webpack",
        "webpack-cli"
      ]
    },
    {
      "groupName": "dev deps",
      "matchPackageNames": [
        "@iiif/presentation-2",
        "@iiif/presentation-3",
        "concurrently",
        "cpx2",
        "http-server",
        "hypothesis",
        "live-server",
        "testcafe-browser-provider-browserstack"
      ]
    },
    {
      "groupName": "runtime deps",
      "matchPackageNames": [
        "@webcomponents/webcomponentsjs",
        "interactjs",
        "iso-language-codes",
        "jquery",
        "jquery-colorbox",
        "jquery-ui",
        "jquery-ui-touch-punch",
        "jquery.browser",
        "lit",
        "soundmanager2"
      ]
    }
  ]
}
